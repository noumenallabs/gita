# Environment Configuration Example
# Copy this file to .env and fill in your values

# Expo Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://gita-api.<your-subdomain>.workers.dev/api
EXPO_PUBLIC_APP_VERSION=1.0.0

# Analytics (Optional)
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_ANALYTICS_ID=your_analytics_id

# Feature Flags
EXPO_PUBLIC_ENABLE_DAILY_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_SHARING=true

# Debug Settings (Development only)
EXPO_PUBLIC_DEBUG_MODE=false
EXPO_PUBLIC_SHOW_PERFORMANCE_MONITOR=false

# App Store URLs (for sharing/rating features)
EXPO_PUBLIC_IOS_APP_URL=https://apps.apple.com/app/bhagavad-gita/id123456789
EXPO_PUBLIC_SAMSUNG_APP_URL=https://galaxystore.samsung.com/detail/com.bhagavadgita.app
EXPO_PUBLIC_STORE_TARGET=samsung

# Social Media (for sharing)
EXPO_PUBLIC_TWITTER_HANDLE=@bhagavadgitaapp
EXPO_PUBLIC_WEBSITE_URL=https://bhagavadgita.app