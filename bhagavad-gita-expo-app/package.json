{
  "name": "bhagavad-gita-expo-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:development": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:production": "eas build --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "update": "eas update",
    "prebuild": "expo prebuild --clean",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "validate": "node scripts/pre-deployment-validation.js",
    "validate:accessibility": "npm test -- --testPathPattern=accessibility",
    "validate:performance": "npm test -- --testPathPattern=performance",
    "validate:integration": "npm test -- --testPathPattern=integration",
    "process-dataset": "node scripts/process-dataset.js",
    "dataset:stats": "node -e \"console.log(JSON.stringify(require('./src/data/summary.json'), null, 2))\"",
    "ci:setup": "npm ci --legacy-peer-deps",
    "ci:test": "npm run lint && npm run type-check && npm run test -- --coverage --watchAll=false",
    "ci:build:dev": "eas build --profile development --non-interactive",
    "ci:build:preview": "eas build --profile preview --non-interactive",
    "ci:build:prod": "eas build --profile production --non-interactive",
    "ci:build:samsung": "eas build --profile samsung-store --platform android --non-interactive",
    "ci:update": "eas update --branch production --message 'Automated deployment'",
    "release:patch": "npm version patch && git push origin main --tags",
    "release:minor": "npm version minor && git push origin main --tags",
    "release:major": "npm version major && git push origin main --tags"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.66.0",
    "expo": "~54.0.13",
    "expo-constants": "^18.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-haptics": "^15.0.7",
    "expo-linear-gradient": "^15.0.7",
    "expo-linking": "^8.0.8",
    "expo-router": "^6.0.12",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "nativewind": "5.0.0-preview.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-css": "0.0.0-nightly.5ce6396",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.11",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "babel-preset-expo": "^54.0.4",
    "clsx": "^2.1.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.12",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.1.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "resolutions": {
    "lightningcss": "1.30.1"
  }
}
